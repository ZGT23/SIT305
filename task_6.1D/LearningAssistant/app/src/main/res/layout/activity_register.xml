<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lets get you"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:layout_marginTop="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup!"
            android:textColor="@color/white"
            android:textSize="40sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext"
            android:hint="Username"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="@color/colorSubtext"
            android:textSize="16sp"
            android:layout_marginBottom="14dp"
            android:contentDescription="Username field" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext"
            android:hint="Email"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:textColor="@color/white"
            android:textColorHint="@color/colorSubtext"
            android:textSize="16sp"
            android:layout_marginBottom="14dp"
            android:contentDescription="Email field" />

        <EditText
            android:id="@+id/etConfirmEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext"
            android:hint="Confirm Email"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:textColor="@color/white"
            android:textColorHint="@color/colorSubtext"
            android:textSize="16sp"
            android:layout_marginBottom="14dp"
            android:contentDescription="Confirm email field" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext"
            android:hint="Password"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:textColor="@color/white"
            android:textColorHint="@color/colorSubtext"
            android:textSize="16sp"
            android:layout_marginBottom="14dp"
            android:contentDescription="Password field" />

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext"
            android:hint="Confirm Password"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:textColor="@color/white"
            android:textColorHint="@color/colorSubtext"
            android:textSize="16sp"
            android:layout_marginBottom="14dp"
            android:contentDescription="Confirm password field" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext"
            android:hint="Phone Number"
            android:paddingHorizontal="16dp"
            android:inputType="phone"
            android:textColor="@color/white"
            android:textColorHint="@color/colorSubtext"
            android:textSize="16sp"
            android:layout_marginBottom="28dp"
            android:contentDescription="Phone number field" />

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Create new Account"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:contentDescription="Create account button" />

    </LinearLayout>
</ScrollView>
