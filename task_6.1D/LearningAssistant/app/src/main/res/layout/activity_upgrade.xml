<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upgrade Account"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unlock more features with a premium plan"
            android:textColor="@color/colorSubtext"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />

        <!-- Starter Plan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Starter"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Improve quiz generation &amp; basic AI hints"
                android:textColor="@color/colorSubtext"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnPurchaseStarter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Purchase - $4.99/mo"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/colorAccent" />
        </LinearLayout>

        <!-- Intermediate Plan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intermediate"
                android:textColor="@color/colorGold"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Improved LLM support &amp; detailed explanations"
                android:textColor="@color/colorSubtext"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnPurchaseIntermediate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Purchase - $9.99/mo"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/colorGold"
                android:textColor="@color/colorBackground" />
        </LinearLayout>

        <!-- Advanced Plan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Advanced"
                android:textColor="#BB86FC"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full learning assistant features &amp; priority support"
                android:textColor="@color/colorSubtext"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnPurchaseAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Purchase - $19.99/mo"
                android:layout_marginTop="16dp"
                android:backgroundTint="#BB86FC" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Cancel"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/colorSubtext" />

    </LinearLayout>
</ScrollView>
